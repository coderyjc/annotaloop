{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AuroraMD",
  "version": "0.4.3",
  "identifier": "com.auroramd.desktop",
  "build": {
    "beforeDevCommand": "npm.cmd run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm.cmd run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AuroraMD",
        "width": 1320,
        "height": 860,
        "minWidth": 980,
        "minHeight": 680,
        "center": true,
        "decorations": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico"]
  }
}
